  "constitutionalGates": {
    "G1": "low-thc-fiber-and-ritual-only — cultivar thc-class is :fiber|:low-thc only; :psychoactive not representable; recreational/high-THC excluded by construction",
    "G2": "non-recreational — never facilitates recreational use; no consumption/dosing guidance; respects the 使用罪",
    "G3": "non-adjudicating / political-neutral — records facts only; legal characterization → danjo/chigiri; no 推進/反対 stance (1 SBT = 1 vote)",
    "G4": "member-principal / no-fiat-inflow — licence fees never from religious-corp funds; okaimono member-principal (ADR-2606012100); nusa never licensee/funder",
    "G5": "no-server-key — authorization = member signature; server signature refused (ADR-2605231525)",
    "G6": "Murakumo-only inference (ADR-2605215000)",
    "G7": "sourcing-honesty — :representative seed; legal/heritage figures flagged + primary-source-citing",
    "G8": "outward-gated — real cultivation / live licence filing / live ingest / publish Council Lv6+ + operator",
