{:lexicon 1
 :id "com.etzhayyim.nusa.hempCultivar"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["hempId" "name" "thcClass" "sourcing"]
    :properties
    {:hempId    {:type "string"}
     :name      {:type "string"}
     :kind      {:type "string" :enum ["cultivar" "landrace"]}
     :thcClass  {:type "string" :enum ["fiber" "low-thc"]
                 :description "G1 INVARIANT — fibre/ritual low-THC ONLY. 'psychoactive' is NOT an allowed value; recreational/high-THC cannot be represented."}
     :fiberUse  {:type "array" :items {:type "string"}
                 :description "e.g. shimenawa, aratae, textile, rope, paper, seed-oil-food"}
     :region    {:type "array" :items {:type "string"}}
     :sourcing  {:type "string" :enum ["representative" "synthesized" "verified"]}}}}}}
