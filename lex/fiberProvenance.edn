{:lexicon 1
 :id "com.etzhayyim.nusa.fiberProvenance"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["cultivar" "thcClass" "fiberUse" "screened"]
    :properties
    {:cultivar  {:type "string" :description "→ hempCultivar.hempId"}
     :thcClass  {:type "string" :enum ["fiber" "low-thc"]
                 :description "G1 — screened; psychoactive is rejected (ValueError) before a provenance record exists"}
     :fiberUse  {:type "array" :items {:type "string"}}
     :region    {:type "array" :items {:type "string"}}
     :screened  {:type "boolean" :const true
                 :description "G1 — record only exists after the THC-class screen passes"}
     :sourcing  {:type "string" :enum ["representative" "synthesized" "verified"]}}}}}}
