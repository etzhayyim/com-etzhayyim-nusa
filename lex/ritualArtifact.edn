{:lexicon 1
 :id "com.etzhayyim.nusa.ritualArtifact"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["riteId" "name" "kind" "purpose" "sourcing"]
    :properties
    {:riteId       {:type "string"}
     :name         {:type "string"}
     :kind         {:type "string" :enum ["shimenawa" "haraegushi" "oonusa" "aratae" "nigitae" "jingu-taima"]}
     :purpose      {:type "string" :const "purification"
                    :description "ritual purpose — purification; hemp's ritual role is cleansing, never intoxication"}
     :material     {:type "string" :enum ["hemp-fiber" "silk"]}
     :usesCultivar {:type "array" :items {:type "string"} :description "→ hempCultivar.hempId (fibre source)"}
     :sourcing     {:type "string" :enum ["representative" "synthesized" "verified"]}}}}}}
