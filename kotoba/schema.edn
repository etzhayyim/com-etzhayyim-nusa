;; nusa (幣) kotoba EAVT schema — ritual/industrial hemp heritage + low-THC cultivation (R0)
;; Mirrors 00-contracts/schemas/ritual-hemp-ontology.kotoba.edn in db/ident form for kqe.
;; G1 INVARIANT: :hemp/thc-class ∈ {:fiber :low-thc} ONLY — :psychoactive is not representable.
[{:db/ident :hemp/id            :db/valueType :db.type/string  :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
 {:db/ident :hemp/name          :db/valueType :db.type/string  :db/cardinality :db.cardinality/one}
 {:db/ident :hemp/kind          :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one}   ;; :cultivar :landrace
 {:db/ident :hemp/thc-class     :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one}   ;; G1 :fiber | :low-thc ONLY
 {:db/ident :hemp/fiber-use     :db/valueType :db.type/keyword :db/cardinality :db.cardinality/many}  ;; :shimenawa :aratae :textile :rope :paper :seed-oil-food
 {:db/ident :hemp/region        :db/valueType :db.type/string  :db/cardinality :db.cardinality/many}
 {:db/ident :hemp/note          :db/valueType :db.type/string  :db/cardinality :db.cardinality/one}
 {:db/ident :hemp/sourcing      :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one}

 {:db/ident :rite/id            :db/valueType :db.type/string  :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
 {:db/ident :rite/name          :db/valueType :db.type/string  :db/cardinality :db.cardinality/one}
 {:db/ident :rite/kind          :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one}
 {:db/ident :rite/purpose       :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one}   ;; :purification
 {:db/ident :rite/material      :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one}
 {:db/ident :rite/uses-cultivar :db/valueType :db.type/string  :db/cardinality :db.cardinality/many}
 {:db/ident :rite/note          :db/valueType :db.type/string  :db/cardinality :db.cardinality/one}
 {:db/ident :rite/sourcing      :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one}

 {:db/ident :rite.event/id      :db/valueType :db.type/string  :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
 {:db/ident :rite.event/name    :db/valueType :db.type/string  :db/cardinality :db.cardinality/one}
 {:db/ident :rite.event/uses-artifact :db/valueType :db.type/string :db/cardinality :db.cardinality/many}
 {:db/ident :rite.event/lineage :db/valueType :db.type/string  :db/cardinality :db.cardinality/many}
 {:db/ident :rite.event/as-of   :db/valueType :db.type/string  :db/cardinality :db.cardinality/one}   ;; 非終末論 history
 {:db/ident :rite.event/note    :db/valueType :db.type/string  :db/cardinality :db.cardinality/one}
